# Service Configuration
ENVIRONMENT=development
LOG_LEVEL=debug
LOG_FORMAT=text

# Database Configuration (dev only - use secrets manager in production)
DB_HOST=localhost
DB_PORT=5432
DB_USER=portfolio_messaging
DB_PASSWORD=portfolio_messaging_dev_pass
DB_NAME=portfolio
DB_SSL_MODE=disable

# RabbitMQ Configuration (dev only - use strong credentials in production)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=messaging
RABBITMQ_PASSWORD=messaging_dev_pass
RABBITMQ_EXCHANGE=contact_messages
RABBITMQ_QUEUE=contact_messages
RABBITMQ_RETRY_DELAYS=1m,5m,30m,2h,12h
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_CONSUMER_TAG=messaging-service

# AWS SES Configuration
AWS_REGION=eu-north-1
SES_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SES_SENDER_EMAIL=noreply@localhost
